# STM32H743 主控板默认配置(板卡专属)。

CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# 时钟/串口
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# 网络能力(该板带 PHY,故在板级打开)
CONFIG_NETWORKING=y
CONFIG_NET_L2_ETHERNET=y
CONFIG_NET_TCP=y
CONFIG_NET_IPV4=y

# CAN(FDCAN1 控制帧通道)
CONFIG_CAN=y
