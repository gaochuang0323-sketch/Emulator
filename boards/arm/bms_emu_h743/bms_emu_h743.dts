/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * BMS 故障模拟装置主控板 —— STM32H743。
 * 所有硬件资源(SPI+DAC81416、CAN、FMC 外部 SRAM、以太网 PHY)在此描述。
 * 换 MCU 时:新建一块 board 目录并改写本文件,app/ 与 drivers/ 代码不动。
 */
/dts-v1/;
#include <st/h7/stm32h743Xi.dtsi>
#include <st/h7/stm32h743zitx-pinctrl.dtsi>

/ {
	model = "BMS Emulator STM32H743 board";
	compatible = "bmsemu,bms-emu-h743";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &usart3;
		zephyr,shell-uart = &usart3;
		zephyr,canbus = &fdcan1;
	};

	/* DAC81416 控制引脚(RESET / LDAC / ALARM),供自定义 BSP 驱动使用 */
	dac_ctrl: dac-control {
		compatible = "bmsemu,dac81416-ctrl";
		reset-gpios = <&gpiod 6 GPIO_ACTIVE_LOW>;
		ldac-gpios  = <&gpiod 5 GPIO_ACTIVE_LOW>;
		alarm-gpios = <&gpiod 4 GPIO_ACTIVE_LOW>;
	};
};

/* DAC81416 走 SPI(24 位帧),刷新率 >= 1kHz;换 DAC 时改此节点 compatible */
&spi1 {
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	status = "okay";
	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;

	dac81416: dac@0 {
		compatible = "bmsemu,dac81416";
		reg = <0>;
		spi-max-frequency = <20000000>;
		status = "okay";
	};
};

/* CAN 控制帧通道(can_protocol) */
&fdcan1 {
	pinctrl-0 = <&fdcan1_rx_pd0 &fdcan1_tx_pd1>;
	pinctrl-names = "default";
	status = "okay";
};

/* 外部 SRAM(FMC),波形引擎 DMA 缓冲 */
&fmc {
	status = "okay";
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* 以太网 PHY(RJ45 10/100M) */
&mac {
	status = "okay";
	pinctrl-names = "default";
};
